{
  "name": "@agent-vault/mac-sync",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-vault-sync": "./dist/cli.js"
