{
  "name": "@agent-vault/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "smoke": "pnpm --filter @agent-vault/server build && pnpm build && node --disable-warning=ExperimentalWarning smoke.mjs"
  },
  "dependencies": {
    "@agent-vault/core": "workspace:*"
  },
  "devDependencies": {
    "@agent-vault/server": "workspace:*",
    "playwright": "^1.57.0",
    "vite": "^7.2.7"
  }
}
