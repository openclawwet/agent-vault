{
  "name": "agent-vault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm -r build",
    "smoke:local": "pnpm --filter @agent-vault/server smoke:local",
    "smoke:sync": "pnpm --filter @agent-vault/sync smoke",
    "smoke:mac-sync": "pnpm --filter @agent-vault/mac-sync smoke",
    "smoke:desktop-ui": "pnpm --filter @agent-vault/mac-sync smoke:ui",
    "smoke:three-device": "pnpm --filter @agent-vault/mac-sync smoke:three-device",
    "smoke:web": "pnpm --filter @agent-vault/web smoke",
    "backup": "node --disable-warning=ExperimentalWarning scripts/backup.mjs",
    "restore": "node --disable-warning=ExperimentalWarning scripts/restore.mjs",
    "package:macbook": "pnpm --filter @agent-vault/core build && pnpm --filter @agent-vault/sync build && pnpm --filter @agent-vault/mac-sync build && node scripts/package-macbook-client.mjs",
    "dev:server": "pnpm --filter @agent-vault/server dev",
    "dev:web": "pnpm --filter @agent-vault/web dev"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  }
}
